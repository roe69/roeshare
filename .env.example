# Copy to .env and adjust. All values have sane defaults except ADMIN_PASSWORD and SECRET.

# Network
HOST=0.0.0.0
PORT=3300
# Public base URL used to build share links and QR codes. No trailing slash.
BASE_URL=http://localhost:3300

# Security
# Admin panel password. REQUIRED for admin access. If unset, admin panel is locked out.
ADMIN_PASSWORD=change-me
# Secret used to sign cookies/tokens AND derive the at-rest file encryption key.
# REQUIRED in production. BACK IT UP: if you lose SECRET, encrypted uploads
# cannot be recovered. Generate one with:
#   bun -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
SECRET=
# Trust X-Forwarded-For / X-Real-IP for the client IP (rate limiting + audit).
# Leave OFF (default) when the server is exposed directly - otherwise a client
# can spoof its IP and defeat rate limits. Set to 1 ONLY behind a trusted
# reverse proxy (nginx, Caddy, Cloudflare, etc).
TRUST_PROXY=0

# Storage
# Directory that holds the sqlite db and uploaded blobs.
DATA_DIR=./data
# Max size of a single file, in bytes. Default 5 GiB.
MAX_FILE_SIZE=5368709120
# Max total size of one share, in bytes. Default 10 GiB.
MAX_SHARE_SIZE=10737418240
# Total storage cap across all shares, in bytes. 0 = unlimited. Default 0.
MAX_TOTAL_SIZE=0
# Upload chunk size advertised to clients, in bytes. Default 8 MiB.
CHUNK_SIZE=8388608
# Max number of files in a single share. Default 10000.
MAX_FILES_PER_SHARE=10000
# Max length of a share/upload password, in characters (bounds argon2 cost). Default 1024.
MAX_PASSWORD_LENGTH=1024

# Sharing defaults
# Require an upload password to create shares (set to a value to require it). Empty = open uploads.
UPLOAD_PASSWORD=
# Default expiry for new shares, in seconds. 0 = never. Default 7 days.
DEFAULT_EXPIRY=604800
# Background sweep interval for expired shares, in seconds. Default 1 hour.
SWEEP_INTERVAL=3600
