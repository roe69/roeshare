# Copy to .env and adjust. All values have sane defaults except ADMIN_PASSWORD and SECRET.

# Network
HOST=0.0.0.0
PORT=3300
# Public base URL used to build share links and QR codes. No trailing slash.
# To serve one instance on multiple domains, list them comma-separated; links
# are built from whichever listed domain the visitor is on, and the first entry
# is the canonical fallback for unrecognized hosts. Requires TRUST_PROXY=1 and a
# reverse proxy that forwards the Host header (and ideally X-Forwarded-Proto).
#   BASE_URL=https://share.example.com,https://files.example.com
BASE_URL=http://localhost:3300

# Branding
# Brand name shown in the sidebar (and page titles). It carries its own colours
# with OSRS-style tags: <col=RRGGBB> colours the text that follows, and
# <b>...</b> makes it bold. To recolour the brand you only change this line - no
# CSS edit needed. The default is a cream "Roe" and a bold orange "Share":
#   APP_NAME=<col=e4e4ce>Roe<b><col=ff6b35>Share</b>
# Examples: blue + green -> <col=5b9dff>Roe<b><col=34d27b>Share</b>
#           plain white  -> <col=ffffff>RoeShare
APP_NAME=<col=e4e4ce>Roe<b><col=ff6b35>Share</b>
# Optional accent re-theming with no CSS edit. Set either/both to a hex colour to
# recolour the whole UI's primary (buttons) and accent (links/highlights). Leave
# blank to keep the default palette. For deeper theming edit public/css/tokens.css.
#   THEME_PRIMARY=#3b82f6
#   THEME_ACCENT=#22c55e
THEME_PRIMARY=
THEME_ACCENT=

# Security
# Admin panel password. REQUIRED for admin access. If unset, admin panel is locked out.
ADMIN_PASSWORD=change-me
# Secret used to sign cookies/tokens AND derive the at-rest file encryption key.
# REQUIRED in production. BACK IT UP: if you lose SECRET, encrypted uploads
# cannot be recovered. Generate one with either:
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=
# Trust X-Forwarded-For / X-Real-IP for the client IP (rate limiting + audit).
# Leave OFF (default) when the server is exposed directly - otherwise a client
# can spoof its IP and defeat rate limits. Set to 1 ONLY behind a trusted
# reverse proxy (nginx, Caddy, Cloudflare, etc).
TRUST_PROXY=0

# Performance: reverse-proxy byte offload (optional, advanced). When set, blobs
# that need no server-side decryption (all E2E shares, plus every file when
# ENCRYPT_AT_REST=0) are served on the preview/streaming path by your reverse
# proxy via kernel sendfile instead of being streamed through this process, so a
# single core can serve far more concurrent video streams. Requires proxy config
# (see the reverse-proxy guide in the README). Leave both blank/off to stream
# through the app (the default).
#   nginx:            X_ACCEL_REDIRECT=/_roeshare_blobs   (an internal location)
#   Apache/Lighttpd:  X_SENDFILE=1                        (X-Sendfile header)
X_ACCEL_REDIRECT=
X_SENDFILE=0

# End-to-end encryption default. New shares are E2E (client-side crypto; the
# server does no crypto and just streams ciphertext) unless set to 0. Off => new
# shares are server-managed by default (server-side at-rest encryption applies).
DEFAULT_E2E=1
# Encrypt server-managed (non-E2E) blobs at rest with AES-256-CTR. Set to 0 to
# store them as plaintext (no server crypto - lets the proxy sendfile them too,
# but raw-disk/backup access can read them). E2E shares are always client-
# encrypted regardless. Existing files keep decrypting via their own stored IV.
ENCRYPT_AT_REST=1

# Storage
# Directory that holds the sqlite db and uploaded blobs.
DATA_DIR=./data
# Max size of a single file, in bytes. Default 5 GiB.
MAX_FILE_SIZE=5368709120
# Max total size of one share, in bytes. Default 10 GiB.
MAX_SHARE_SIZE=10737418240
# Total storage cap across all shares, in bytes. 0 = unlimited. Default 0.
MAX_TOTAL_SIZE=0
# Upload chunk size advertised to clients, in bytes. Default 8 MiB.
CHUNK_SIZE=8388608
# Max number of files in a single share. Default 10000.
MAX_FILES_PER_SHARE=10000
# Max length of a share/upload password, in characters (bounds argon2 cost). Default 1024.
MAX_PASSWORD_LENGTH=1024

# Sharing defaults
# Require an upload password to create shares (set to a value to require it). Empty = open uploads.
UPLOAD_PASSWORD=
# Default expiry for new shares, in seconds. 0 = never. Default 7 days.
DEFAULT_EXPIRY=604800
# Background sweep interval for expired shares, in seconds. Default 1 hour.
SWEEP_INTERVAL=3600

# Programmatic API (backups, other servers)
# There is NOTHING to configure here for the API: other applications upload via
# API keys, which you create and manage in the admin panel under "API keys"
# (each key can be scoped with its own size/expiry/share limits). The panel's
# "API docs" page documents every endpoint with copy-ready examples. Keys are
# stored hashed in the database, so they do not live in this file.
